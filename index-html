<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>My Products</title>
<style>
body {
  font-family: Arial, sans-serif;
  background: #fff;
  margin: 20px;
  color: #000;
}
#products { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px; }
.product { border: 1px solid #ccc; padding: 10px; width: 250px; }
.product img { width: 100%; }
#adminBtn {
  position: fixed;
  top: 10px; right: 10px;
  padding: 8px 12px;
  cursor: pointer;
}
#adminPanel {
  display: none;
  position: fixed;
  top: 50px; left: 50%; transform: translateX(-50%);
  background: #fff; border: 2px solid #000; padding: 20px; max-height: 90%; overflow-y: auto; z-index: 999;
}
#adminPanel h2 { margin-top: 0; }
</style>
</head>
<body>

<button id="adminBtn">Admin</button>

<div id="products"></div>

<!-- Admin Panel -->
<div id="adminPanel">
<h2>Admin</h2>
<label>Enter Passcode:</label>
<input type="password" id="passcode" placeholder="Password" />
<button onclick="checkPasscode()">OK</button>
<button onclick="closeAdmin()">Close</button>

<div id="adminControls" style="display:none;">
<h3>Add/Edit Product</h3>
<input type="hidden" id="editIndex" />
<input type="text" placeholder="Name" id="prodName"/><br/>
<input type="text" placeholder="Color" id="prodColor"/><br/>
<input type="text" placeholder="Size" id="prodSize"/><br/>
<textarea placeholder="Description" id="prodDesc"></textarea><br/>
<input type="text" placeholder="Image URL" id="prodImage"/><br/>
<input type="number" placeholder="Price" id="prodPrice"/><br/>
<input type="number" placeholder="Discount %" id="prodDiscount"/><br/>
<label>In Stock:</label>
<select id="prodStock">
  <option value="yes">Yes</option>
  <option value="no">No</option>
</select><br/>
<label>Facebook Link:</label>
<input type="text" placeholder="Facebook URL" id="prodFacebook"/><br/>
<button onclick="saveProduct()">Save</button>

<h3>Existing Products</h3>
<div id="manageProducts"></div>
</div>
</div>

<script>
const passcode = "1234"; // Change to your password
const storageKey = 'products';

document.getElementById("adminBtn").onclick = () => {
  document.getElementById("adminPanel").style.display = "block";
};
function closeAdmin() {
  document.getElementById("adminPanel").style.display = "none";
  document.getElementById("adminControls").style.display = "none";
  resetForm();
}
function checkPasscode() {
  if (document.getElementById("passcode").value === passcode) {
    alert("Access granted");
    document.getElementById("adminControls").style.display = "block";
    loadProducts();
    loadManage();
  } else {
    alert("Wrong password");
  }
}
function loadProducts() {
  const container = document.getElementById("products");
  container.innerHTML = "";
  const products = JSON.parse(localStorage.getItem(storageKey)) || [];
  products.forEach((p) => {
    const inStockText = p.stock === "yes" ? "In Stock" : "Sold Out";
    const discountText = p.discount ? `(Discount: ${p.discount}%)` : "";
    container.innerHTML += `
      <div class="product">
        <h4>${p.name} ${discountText}</h4>
        <img src="${p.image}" />
        <p>Color: ${p.color}</p>
        <p>Size: ${p.size}</p>
        <p>${p.desc}</p>
        <p>Price: $${p.price} ${p.discount ? '(after discount: $' + (p.price - p.price*p.discount/100).toFixed(2) + ')' : ''}</p>
        <p>Status: ${inStockText}</p>
        <a href="${p.facebook}" target="_blank">Facebook</a>
      </div>
    `;
  });
}
function loadManage() {
  const container = document.getElementById("manageProducts");
  container.innerHTML = "";
  const products = JSON.parse(localStorage.getItem(storageKey)) || [];
  products.forEach((p, i) => {
    container.innerHTML += `
      <div class="product">
        <strong>${p.name}</strong>
        <button onclick="editProduct(${i})">Edit</button>
        <button onclick="deleteProduct(${i})">Remove</button>
      </div>
    `;
  });
}
function saveProduct() {
  const name = document.getElementById("prodName").value;
  const color = document.getElementById("prodColor").value;
  const size = document.getElementById("prodSize").value;
  const desc = document.getElementById("prodDesc").value;
  const image = document.getElementById("prodImage").value;
  const price = parseFloat(document.getElementById("prodPrice").value);
  const discount = parseFloat(document.getElementById("prodDiscount").value) || 0;
  const stock = document.getElementById("prodStock").value;
  const facebook = document.getElementById("prodFacebook").value;

  if (!name || !image || isNaN(price)) {
    alert("Fill all required fields");
    return;
  }

  const products = JSON.parse(localStorage.getItem(storageKey)) || [];
  const index = document.getElementById("editIndex").value;
  const newProd = { name, color, size, desc, image, price, discount, stock, facebook };
  if (index !== "") {
    products[index] = newProd;
  } else {
    products.push(newProd);
  }
  localStorage.setItem(storageKey, JSON.stringify(products));
  loadProducts();
  loadManage();
  resetForm();
}
function editProduct(i) {
  const products = JSON.parse(localStorage.getItem(storageKey)) || [];
  const p = products[i];
  document.getElementById("prodName").value = p.name;
  document.getElementById("prodColor").value = p.color;
  document.getElementById("prodSize").value = p.size;
  document.getElementById("prodDesc").value = p.desc;
  document.getElementById("prodImage").value = p.image;
  document.getElementById("prodPrice").value = p.price;
  document.getElementById("prodDiscount").value = p.discount;
  document.getElementById("prodStock").value = p.stock;
  document.getElementById("prodFacebook").value = p.facebook;
  document.getElementById("editIndex").value = i;
}
function deleteProduct(i) {
  if (confirm("Remove?")) {
    const products = JSON.parse(localStorage.getItem(storageKey)) || [];
    products.splice(i,1);
    localStorage.setItem(storageKey, JSON.stringify(products));
    loadProducts();
    loadManage();
  }
}
function resetForm() {
  document.getElementById("prodName").value = "";
  document.getElementById("prodColor").value = "";
  document.getElementById("prodSize").value = "";
  document.getElementById("prodDesc").value = "";
  document.getElementById("prodImage").value = "";
  document.getElementById("prodPrice").value = "";
  document.getElementById("prodDiscount").value = "";
  document.getElementById("prodStock").value = "yes";
  document.getElementById("prodFacebook").value = "";
  document.getElementById("editIndex").value = "";
}
</script>

</body>
</html>
